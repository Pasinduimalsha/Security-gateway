# Security Gateway Root Environment Variables

# JWT Configuration
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES=1h

# Port Configurations
AUTH_PORT=7001
PROXY_PORT=3000
ENCLAVE_PORT=4000
AUDIT_PORT=5001

# Database Configuration
MONGO_URI=mongodb://localhost:27017/security-gateway

# Development Flags
NODE_ENV=development
USE_LOCAL_SDK=true

# Security Parameters
ENCLAVE_MRENCLAVE=simulated_mrenclave_hash_12345
BLS_PRIVATE_KEY=simulated_bls_private_key_99999
ENCLAVE_CLASSIFICATION=TS
