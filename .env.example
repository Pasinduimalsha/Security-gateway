# Security Gateway Root Environment Variables

# JWT Configuration
JWT_SECRET=
JWT_EXPIRES=

# Port Configurations
AUTH_PORT=
PROXY_PORT=
ENCLAVE_PORT=
AUDIT_PORT=

# Database Configuration
MONGO_URI=

# Development Flags
NODE_ENV=development
USE_LOCAL_SDK=true

# Security Parameters
ENCLAVE_MRENCLAVE=
BLS_PRIVATE_KEY=
ENCLAVE_CLASSIFICATION=

# Dashboard API Endpoints (Vite Frontend Configuration)
VITE_API_AUDIT=
VITE_API_PROXY=
VITE_API_AUTH=
VITE_API_ENCLAVE=

# Rate Limiting Parameters (Optional Overrides)
# RATE_LIMIT_GLOBAL_WINDOW_MS=15000
# RATE_LIMIT_GLOBAL_MAX=100
# RATE_LIMIT_AUTH_WINDOW_MS=15000
# RATE_LIMIT_AUTH_MAX=10
# RATE_LIMIT_SENSITIVE_WINDOW_MS=15000
# RATE_LIMIT_SENSITIVE_MAX=10


