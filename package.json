{
  "name": "security-gateway-sdk",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "proxy",
    "enclave",
    "audit",
    "auth",
    "dashboard"
  ],
  "scripts": {
    "install:all": "npm install",
    "dev": "concurrently -c \"cyan.bold,magenta.bold,yellow.bold,green.bold,blue.bold,red.bold,white.bold\" -n \"PROXY,ENCLAVE,AUDIT,AUTH,DASHBOARD,DOCS\" \"npm run dev -w proxy\" \"npm run dev -w enclave\" \"npm run dev -w audit\" \"npm run dev -w auth\" \"npm run dev -w dashboard\" \"npm run dev:docs\"",
    "dev:proxy": "npm run dev -w proxy",
    "dev:enclave": "npm run dev -w enclave",
    "dev:audit": "npm run dev -w audit",
    "dev:auth": "npm run dev -w auth",
    "dev:dashboard": "npm run dev -w dashboard",
    "dev:docs": "nodemon swagger-server.js",
    "test": "node tests/integration.test.js"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "express": "^5.2.1",
    "nodemon": "^3.1.14",
    "swagger-ui-express": "^5.0.1"
  }
}
