{
  "openapi": "3.0.0",
  "info": {
    "title": "Security Gateway SDK Documentation",
    "version": "1.0.0",
    "description": "Unified Swagger API Documentation for the Bell-LaPadula based Security Gateway"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Security Proxy (Main Gateway Port 3000)"
    },
    {
      "url": "http://localhost:5001",
      "description": "Audit Service (Port 5001)"
    },
    {
      "url": "http://localhost:7001",
      "description": "Auth Service (Port 7001)"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "paths": {
    "/api/auth/register": {
      "post": {
        "summary": "Register a new user (via Proxy)",
        "description": "Registers a user. The request is proxied to the Auth service.",
        "tags": ["Gateway"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": { "type": "string", "example": "pasindu" },
                  "password": { "type": "string", "example": "password123" },
                  "role": { "type": "string", "enum": ["admin", "analyst", "reader"], "example": "admin" }
                },
                "required": ["username", "password"]
              }
            }
          }
        },
        "responses": { "201": { "description": "Success" } }
      }
    },
    "/api/auth/login": {
      "post": {
        "summary": "Login a user (via Proxy)",
        "description": "Authenticates and returns a JWT token.",
        "tags": ["Gateway"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": { "type": "string", "example": "pasindu" },
                  "password": { "type": "string", "example": "password123" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "JWT Token returned" } }
      }
    },
    "/api/enclave": {
      "get": {
        "summary": "Access Secure Enclave (via Proxy)",
        "description": "Establishes ECDH secure channel and executes TEE logic. Requires Secret 'S' clearance.",
        "tags": ["Gateway"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Securely decrypted data from TEE" },
          "401": { "description": "Unauthorized" },
          "403": { "description": "Forbidden - MLS Access Denied" }
        }
      }
    },
    "/proof": {
      "get": {
        "summary": "Get BLS Aggregate Signature (Audit)",
        "description": "Retrieves the mathematical non-repudiation proof for all gateway events.",
        "tags": ["Audit"],
        "responses": {
          "200": { "description": "Aggregate signature hash" }
        }
      }
    }
  }
}
